{
    "name": "DevAnsible",
    "build": {
        "dockerfile": "Dockerfile"
    },
    // Acceso al Docker del host (docker-outside-of-docker): monta el socket y
    // agrega el remoteUser al grupo docker al buildear. Necesario para correr
    // los tests de Molecule (crean contenedores en el daemon del host).
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "files.associations": {
                    "*.yml": "ansible"
                },
                "editor.defaultFormatter": "redhat.ansible",
                "editor.formatOnSave": true,
                "files.trimTrailingWhitespace": true,
                "files.insertFinalNewline": true,
                "ansible.python.interpreterPath": "/home/appuser/ansible-venv/bin/python3",
                "ansible.validation.enabled": true,
                "ansible.completion.provideRedirectModules": true,
                "ansible.completion.provideModuleOptionAliases": true
            },
            "extensions": [
                "redhat.vscode-yaml",
                "redhat.ansible",
                "anthropic.claude-code",
                "timonwong.shellcheck",
                "DavidAnson.vscode-markdownlint",
                "ms-python.python"
            ]
        }
    },
    // Antes del setup: el volume nombrado se crea owned por root la primera vez,
    // así que hacemos chown a appuser para poder escribir adentro (sin esto el cp
    // de abajo falla con "Permission denied" y Claude no encuentra credenciales).
    // Luego, si el volume arranca vacío (primer rebuild tras agregar el mount), lo
    // sembramos desde el backup en /app/.ansible/claude-persist (memoria, sesiones
    // y credenciales de Claude Code). En rebuilds siguientes el volume ya tiene
    // datos y no se pisa. ~/.claude.json vive fuera del volume, así que se restaura
    // solo si falta.
    // Mismo patrón para ~/.config/gh (credenciales de GitHub CLI): chown + seed
    // opcional desde el backup. Si no hay backup, basta con hacer 'gh auth login'
    // una vez y el volume lo persiste entre rebuilds.
    "postCreateCommand": "sudo mkdir -p /home/appuser/.claude && sudo chown appuser:appuser /home/appuser/.claude && if [ -z \"$(ls -A /home/appuser/.claude 2>/dev/null)\" ] && [ -d /app/.ansible/claude-persist/dot-claude ]; then cp -a /app/.ansible/claude-persist/dot-claude/. /home/appuser/.claude/; fi; if [ ! -f /home/appuser/.claude.json ] && [ -f /app/.ansible/claude-persist/dot-claude.json ]; then cp -a /app/.ansible/claude-persist/dot-claude.json /home/appuser/.claude.json; fi; sudo mkdir -p /home/appuser/.config/gh && sudo chown appuser:appuser /home/appuser/.config && sudo chown -R appuser:appuser /home/appuser/.config/gh && if [ -z \"$(ls -A /home/appuser/.config/gh 2>/dev/null)\" ] && [ -d /app/.ansible/claude-persist/dot-config-gh ]; then cp -a /app/.ansible/claude-persist/dot-config-gh/. /home/appuser/.config/gh/; fi; pip install --quiet -r /app/requirements-dev.txt && ansible-galaxy install -r collections/requirements.yml && pre-commit install",
    "containerEnv": {
        "ANSIBLE_FORCE_COLOR": "1",
        "ANSIBLE_NOCOLOR": "0"
    },
    "mounts": [
        "source=${localEnv:SSH_AUTH_SOCK},target=/run/host-ssh-agent.sock,type=bind,consistency=cached",
        // Persiste ~/.claude (memoria, sesiones, credenciales de Claude Code) entre
        // rebuilds del devcontainer. Se siembra desde el backup vía postCreateCommand.
        "source=devansible-claude,target=/home/appuser/.claude,type=volume",
        // Persiste ~/.config/gh (credenciales de GitHub CLI) entre rebuilds. Sin
        // esto, cada rebuild obliga a re-hacer 'gh auth login'.
        "source=devansible-gh,target=/home/appuser/.config/gh,type=volume"
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/run/host-ssh-agent.sock"
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
    "workspaceFolder": "/app",
    "remoteUser": "appuser"
}
